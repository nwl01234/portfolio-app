import os
import json
import asyncio
from dotenv import load_dotenv
from aiogram import Bot, Dispatcher, types, F
from aiogram.filters import Command
from aiogram.types import WebAppInfo, ReplyKeyboardMarkup, KeyboardButton, InlineKeyboardMarkup, InlineKeyboardButton

load_dotenv()

# ═══════════════════════════════════════════════════════════════
# CONFIGURATION
# ═══════════════════════════════════════════════════════════════
TOKEN = os.getenv("TOKEN")
ADMIN_ID = int(os.getenv("ADMIN_ID"))  # Your Telegram ID
USDT_WALLET = os.getenv("USDT_WALLET")  # Your USDT TRC20 address
WEBAPP_URL = os.getenv("WEBAPP_URL")  # Your GitHub Pages URL

bot = Bot(token=TOKEN)
dp = Dispatcher()

# Store active conversations (client_id -> last_message_id)
conversations = {}

# ═══════════════════════════════════════════════════════════════
# MAIN MENU
# ═══════════════════════════════════════════════════════════════
def main_menu():
    return ReplyKeyboardMarkup(
        keyboard=[
            [KeyboardButton(text="🚀 OPEN PORTFOLIO", web_app=WebAppInfo(url=WEBAPP_URL))],
            [KeyboardButton(text="💬 Contact Developer")]
        ],
        resize_keyboard=True
    )

# ═══════════════════════════════════════════════════════════════
# START COMMAND
# ═══════════════════════════════════════════════════════════════
@dp.message(Command("start"))
async def cmd_start(message: types.Message):
    await message.answer(
        "⬛ **NWL - TELEGRAM AUTOMATION**\n\n"
        "Professional bot development for US market:\n"
        "• AI Support Agents (GPT-4)\n"
        "• Web Scrapers & Monitors\n"
        "• Community Management\n\n"
        "🚀 **Open Portfolio** to see live demos\n"
        "💬 **Contact Me** for custom projects",
        reply_markup=main_menu(),
        parse_mode="Markdown"
    )

# ═══════════════════════════════════════════════════════════════
# ORDER PROCESSING (from WebApp)
# ═══════════════════════════════════════════════════════════════
@dp.message(F.content_type == "web_app_data")
async def process_webapp_data(message: types.Message):
    data = json.loads(message.web_app_data.data)
    
    if data['type'] == 'order':
        # Format order items
        items_list = "\n".join([f"  • {item['name']} - ${item['price']}" for item in data['cart']])
        
        # Payment instructions
        if data['method'] == 'usdt':
            payment_info = (
                f"💎 **USDT TRC20 Payment:**\n"
                f"`{USDT_WALLET}`\n\n"
                f"After payment, send me the transaction hash or screenshot."
            )
        else:
            payment_info = (
                f"👛 **Telegram Wallet Payment:**\n"
                f"I'll send you a payment link via @wallet shortly."
            )
        
        # Send confirmation to client
        await message.answer(
            f"✅ **ORDER CONFIRMED**\n\n"
            f"**Items:**\n{items_list}\n\n"
            f"💰 **Total:** {data['total']}\n\n"
            f"{payment_info}\n\n"
            f"Questions? Just type your message below.",
            parse_mode="Markdown"
        )
        
        # Notify admin with inline reply button
        admin_msg = await bot.send_message(
            ADMIN_ID,
            f"🚨 **NEW ORDER**\n\n"
            f"👤 {message.from_user.full_name}\n"
            f"🆔 `{message.from_user.id}`\n"
            f"👤 @{message.from_user.username or 'No username'}\n\n"
            f"**Order Details:**\n{items_list}\n\n"
            f"💰 {data['total']}\n"
            f"💳 Payment: {data['method'].upper()}",
            parse_mode="Markdown",
            reply_markup=InlineKeyboardMarkup(inline_keyboard=[
                [InlineKeyboardButton(text="💬 Reply to Client", callback_data=f"reply_{message.from_user.id}")]
            ])
        )
        
        # Store conversation
        conversations[message.from_user.id] = admin_msg.message_id

# ═══════════════════════════════════════════════════════════════
# CLIENT MESSAGES
# ═══════════════════════════════════════════════════════════════
@dp.message(F.text)
async def handle_messages(message: types.Message):
    user_id = message.from_user.id
    
    # If ADMIN sends message
    if user_id == ADMIN_ID:
        # Admin must reply to a forwarded message
        if message.reply_to_message:
            # Extract client ID from the replied message
            try:
                replied_text = message.reply_to_message.text or message.reply_to_message.caption
                if "🆔" in replied_text:
                    client_id = int(replied_text.split("🆔 `")[1].split("`")[0])
                    
                    # Send admin's message to client
                    await bot.send_message(
                        client_id,
                        f"👨‍💻 **Developer:**\n{message.text}",
                        parse_mode="Markdown"
                    )
                    
                    await message.answer("✅ Message sent to client.")
                else:
                    await message.answer("⚠️ Please reply to a client's message that contains their ID.")
            except Exception as e:
                await message.answer(f"❌ Error: {str(e)}\n\nMake sure you're replying to a client message.")
        else:
            await message.answer("⚠️ Reply to a client's message to respond to them.")
        return
    
    # If CLIENT sends message
    if message.text == "💬 Contact Developer":
        await message.answer(
            "💬 **Developer Chat Active**\n\n"
            "Type your message below. I'll respond as soon as possible.",
            parse_mode="Markdown"
        )
        
        # Notify admin that client wants to chat
        admin_msg = await bot.send_message(
            ADMIN_ID,
            f"💬 **NEW MESSAGE REQUEST**\n\n"
            f"👤 {message.from_user.full_name}\n"
            f"🆔 `{message.from_user.id}`\n"
            f"👤 @{message.from_user.username or 'No username'}\n\n"
            f"Client initiated conversation. Waiting for message...",
            parse_mode="Markdown"
        )
        conversations[user_id] = admin_msg.message_id
        return
    
    # Regular client message -> Forward to admin
    if message.text != "🚀 OPEN PORTFOLIO":
        # Send to admin with reply capability
        admin_msg = await bot.send_message(
            ADMIN_ID,
            f"💬 **CLIENT MESSAGE**\n\n"
            f"👤 {message.from_user.full_name}\n"
            f"🆔 `{message.from_user.id}`\n"
            f"👤 @{message.from_user.username or 'No username'}\n\n"
            f"**Message:**\n{message.text}",
            parse_mode="Markdown",
            reply_markup=InlineKeyboardMarkup(inline_keyboard=[
                [InlineKeyboardButton(text="💬 Reply", callback_data=f"reply_{user_id}")]
            ])
        )
        
        conversations[user_id] = admin_msg.message_id
        
        await message.answer(
            "✅ Message sent to developer. You'll get a response soon!",
            parse_mode="Markdown"
        )

# ═══════════════════════════════════════════════════════════════
# INLINE BUTTON HANDLER (Reply button)
# ═══════════════════════════════════════════════════════════════
@dp.callback_query(F.data.startswith("reply_"))
async def handle_reply_button(callback: types.CallbackQuery):
    client_id = int(callback.data.split("_")[1])
    
    await callback.message.answer(
        f"💬 **Reply to client {client_id}:**\n\n"
        f"Reply to THIS message with your text.",
        parse_mode="Markdown"
    )
    await callback.answer()

# ═══════════════════════════════════════════════════════════════
# MAIN
# ═══════════════════════════════════════════════════════════════
async def main():
    print("🚀 Bot starting...")
    await bot.delete_webhook(drop_pending_updates=True)
    print("✅ Bot is running!")
    await dp.start_polling(bot)

if __name__ == "__main__":
    asyncio.run(main())